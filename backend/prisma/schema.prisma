// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DummyItem {
  id   Int    @id @default(autoincrement())
  name String
}

model User {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  firstName     String
  lastName      String
  email         String         @unique
  passwordHash  String
  connections   IntegrationConnection[]
  agents        Agent[]
  conversations Conversation[]
}

model Integration {
  id           Int                    @id @default(autoincrement())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  uniqueKey    String                 @unique
  provider     String
  displayName  String?
  logoUrl      String?
  enabled      Boolean                @default(true)
  actions      IntegrationAction[]
  connections  IntegrationConnection[]
}

model IntegrationAction {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  integration  Integration @relation(fields: [integrationId], references: [id])
  integrationId Int
  actionKey    String
  actionName   String?
  description  String?
  jsonSchema   Json?       // OpenAI tool parameters schema from Nango script config
  /// "action" for Nango actions, "sync" for Nango syncs.
  type         String      @default("action")
  /// For syncs/actions, the primary data model name (e.g. "GmailEmail").
  dataModel    String?
  enabled      Boolean     @default(true)
  agentTools   AgentTool[]

  @@unique([integrationId, actionKey])
}

model IntegrationConnection {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id])
  userId            Int
  integration       Integration @relation(fields: [integrationId], references: [id])
  integrationId     Int
  nangoConnectionId String
  providerConfigKey String?
  provider          String?
  status            String     @default("CONNECTED")

  @@unique([userId, integrationId])
}

model Agent {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  userId        Int
  name          String
  systemPrompt  String
  tools         AgentTool[]
  conversations ConversationAgent[]
}

model Conversation {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  /// Human-friendly title generated from the first user message.
  title          String?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  messages       Message[]
  toolExecutions ToolExecution[]
  agents         ConversationAgent[]
}

model Message {
  id                Int            @id @default(autoincrement())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  conversation      Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId    String
  role              String         // "user" | "assistant" | "tool"
  content           String
  toolCallId        String?        // OpenAI tool_call id, for role "tool"
  toolCallsJson     Json?          // For role "assistant": tool_calls array for API history
  toolExecution     ToolExecution? @relation(fields: [toolExecutionId], references: [id], onDelete: SetNull)
  toolExecutionId   Int?
}

model ToolExecution {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  toolName       String
  inputJson      Json
  outputJson     Json?
  status         String        // "success" | "failure"
  statusReason   String?
  messages       Message[]
}

model AgentTool {
  id                 Int               @id @default(autoincrement())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  agent              Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId            Int
  integrationAction  IntegrationAction @relation(fields: [integrationActionId], references: [id])
  integrationActionId Int

  @@unique([agentId, integrationActionId])
}

model ConversationAgent {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  agent          Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId        Int

  @@unique([conversationId, agentId])
}
