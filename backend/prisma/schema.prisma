// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DummyItem {
  id   Int    @id @default(autoincrement())
  name String
}

model User {
  id           Int                     @id @default(autoincrement())
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  firstName    String
  lastName     String
  email        String                  @unique
  passwordHash String
  connections  IntegrationConnection[]
  agents       Agent[]
}

model Integration {
  id           Int                    @id @default(autoincrement())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  uniqueKey    String                 @unique
  provider     String
  displayName  String?
  logoUrl      String?
  enabled      Boolean                @default(true)
  actions      IntegrationAction[]
  connections  IntegrationConnection[]
}

model IntegrationAction {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  integration  Integration @relation(fields: [integrationId], references: [id])
  integrationId Int
  actionKey    String
  actionName   String?
  description  String?
  enabled      Boolean     @default(true)
  agentTools   AgentTool[]

  @@unique([integrationId, actionKey])
}

model IntegrationConnection {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id])
  userId            Int
  integration       Integration @relation(fields: [integrationId], references: [id])
  integrationId     Int
  nangoConnectionId String
  providerConfigKey String?
  provider          String?
  status            String     @default("CONNECTED")

  @@unique([userId, integrationId])
}

model Agent {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  userId       Int
  name         String
  systemPrompt String
  tools        AgentTool[]
}

model AgentTool {
  id                 Int               @id @default(autoincrement())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  agent              Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId            Int
  integrationAction  IntegrationAction @relation(fields: [integrationActionId], references: [id])
  integrationActionId Int

  @@unique([agentId, integrationActionId])
}
